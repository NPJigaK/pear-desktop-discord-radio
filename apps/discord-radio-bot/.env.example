# The CLI scripts load this file automatically through Node's built-in
# `.env` support when `.env` exists in the bot package root.

DISCORD_TOKEN=
DISCORD_APPLICATION_ID=
DISCORD_GUILD_ID=
DISCORD_CONTROLLER_USER_ID=
PEAR_CLIENT_ID=pear-desktop-discord-radio

# Optional. Must stay exactly 127.0.0.1 if set.
PEAR_HOST=127.0.0.1
PEAR_PORT=26538

# The supported v2 path assumes the repo-root Pear fork and the launch
# contract documented in ../../docs/private-pear-fork.md.
# Optional: override only if the patched Pear root lives outside this repo.
# PEAR_DESKTOP_DIR=E:\github\pear-desktop-discord-radio

# Optional fallback. Used only when the app-managed FFmpeg binary
# is unavailable or when you intentionally want doctor/runtime to
# fall back after the app-managed probe fails.
# FFMPEG_PATH=C:\ffmpeg\bin\ffmpeg.exe

# Optional. Example: info, debug, warn, error.
# LOG_LEVEL=info
